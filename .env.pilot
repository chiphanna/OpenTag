# Minimal env for the Skill Builder pilot. Copy the set you need into .env.
# Only Slack + OpenAI are required; leave Linear/Notion blank (no MCP this pilot).

# Slack (api.slack.com/apps → create from slack-app-manifest.json)
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...

# Model — pilot runs on OpenAI (runtime.ts uses the openaiText adapter).
OPENAI_API_KEY=sk-...
# AGENT_MODEL=openai/gpt-5.5   # default; override if desired

# Agent backend endpoint (local runtime started by `pnpm ... runtime`).
AGENT_URL=http://localhost:8200/api/copilotkit/agent/triage/run

# --- intentionally left blank for the pilot ---
# LINEAR_API_KEY=
# NOTION_TOKEN=
# NOTION_MCP_AUTH_TOKEN=
